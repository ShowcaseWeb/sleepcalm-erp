# ============================================================
# SleepCalm ERP - Variáveis de Ambiente
# ============================================================

# Servidor
NODE_ENV=development
PORT=4000
API_VERSION=v1

# Database
DATABASE_URL="postgresql://sleepcalm_admin:SleepcAlm@2024#Secure!@localhost:5432/sleepcalm_erp"

# Redis
REDIS_URL="redis://:SleepcalmRedis@2024@localhost:6379"

# JWT
JWT_SECRET=JWT_ULTRA_SECRET_SLEEPCALM_2024_CHANGE_THIS_IN_PRODUCTION
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=JWT_REFRESH_ULTRA_SECRET_SLEEPCALM_2024_CHANGE_THIS
JWT_REFRESH_EXPIRES_IN=7d

# BCrypt
BCRYPT_ROUNDS=12

# Frontend
FRONTEND_URL=http://localhost:3000

# Upload
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE=52428800
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,pdf,mp4,mov,avi,xlsx,xls,docx,doc,xml

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@sleepcalm.com.br
SMTP_PASS=your_smtp_password
SMTP_FROM=SleepCalm ERP <noreply@sleepcalm.com.br>

# Lalamove API
LALAMOVE_API_KEY=your_lalamove_api_key
LALAMOVE_API_SECRET=your_lalamove_api_secret
LALAMOVE_BASE_URL=https://rest.lalamove.com
LALAMOVE_MARKET=BR

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Logs
LOG_LEVEL=debug
LOG_FILE=./logs/app.log
